# =============================================================================
# Polyagent DevContainer — Configuration (base variant)
# =============================================================================
# This file is the single source of container configuration.
# After editing: Ctrl+Shift+P → "Rebuild Container"
#
# Multiple instances:
#   cp .env .env.project-b
#   # change COMPOSE_PROJECT_NAME and CONTAINER_NAME in .env.project-b
#   docker compose --env-file .env.project-b up -d
# =============================================================================

# --- Identity (unique per instance) ---
COMPOSE_PROJECT_NAME=polyagent-devcontainer
CONTAINER_NAME=polyagent-dev
IMAGE_NAME=polyagent-devcontainer
IMAGE_TAG=latest

# --- Runtime ---
TZ=UTC

# --- Node.js ---
# For project code (empty = no project Node.js installed)
# Set when the project needs Node.js. Example: PROJECT_NODE_VERSION=20
PROJECT_NODE_VERSION=

# --- Workspace ---
# Empty = use the parent folder of .devcontainer
# Windows: C:\Users\you\project → /c/Users/you/project
HOST_WORKSPACE_PATH=
