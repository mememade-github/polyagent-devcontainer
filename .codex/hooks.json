{
  "hooks": {
    "SessionStart": [
      {
        "command": "bash \"${CODEX_PROJECT_DIR:-.}/.codex/hooks/session-start.sh\"",
        "timeout": 15
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "command": "bash \"${CODEX_PROJECT_DIR:-.}/.codex/hooks/pre-commit-gate.sh\"",
        "timeout": 5
      },
      {
        "matcher": "Bash",
        "if": "Bash(git push*)",
        "command": "bash \"${CODEX_PROJECT_DIR:-.}/.codex/hooks/pre-push-gate.sh\"",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "command": "bash \"${CODEX_PROJECT_DIR:-.}/.codex/hooks/refinement-gate.sh\"",
        "timeout": 10
      }
    ]
  }
}
