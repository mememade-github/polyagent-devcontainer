# =============================================================================
# Claude DevContainer - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# 환경 설정 (민감 정보)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/settings.local.json
*.code-workspace

# -----------------------------------------------------------------------------
# Claude Code (런타임 마커 — 커밋 불필요)
# -----------------------------------------------------------------------------
.claude/.tool-call-counter
.claude/.last-verification*
.claude/.last-evolution*
.claude/.last-push-url*
.claude/.heartbeat
.claude/.pending-review
.claude/.review-done
.claude/subagent.log
.claude/.update-check-cache
.claude/settings.local.json
.mcp.json

# -----------------------------------------------------------------------------
# 기타
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
*.tmp
*.temp
*.bak
*~
